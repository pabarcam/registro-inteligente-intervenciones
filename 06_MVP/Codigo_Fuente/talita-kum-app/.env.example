# Variables de entorno — Talita Kum MVP
# Copiar a .env y completar los valores.

# Obligatorias
SESSION_SECRET=generar-un-secreto-largo-y-unico
PORT=3000

# Base de datos (opcional; por defecto usa database/database.db)
# DATA_DIR=./data
# DB_PATH=./database/database.db

# Correo SMTP (opcional; sin esto no se envian notificaciones)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=tu-correo@gmail.com
# SMTP_PASS=tu-app-password
# EMAIL_FROM=Talita-Kum <tu-correo@gmail.com>

# Resumen IA — agente LLM gratuito via Groq (opcional)
# Obtén API key gratis en https://console.groq.com
# Sin configurar, el sistema usa resumen estructurado local (fallback TCC).
AI_SUMMARY_API_URL=https://api.groq.com/openai/v1/chat/completions
# AI_SUMMARY_API_KEY=TU_API_KEY_GROQ
AI_SUMMARY_MODEL=llama3-70b-8192

# Alternativa: DeepSeek (requiere saldo)
# AI_SUMMARY_API_URL=https://api.deepseek.com/v1/chat/completions
# AI_SUMMARY_API_KEY=sk-...
# AI_SUMMARY_MODEL=deepseek-chat

# Transcripcion de voz externa (opcional)
# VOICE_TRANSCRIPTION_API_URL=
# VOICE_TRANSCRIPTION_API_KEY=

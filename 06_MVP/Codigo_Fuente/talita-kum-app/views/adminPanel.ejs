<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Panel administrador - Talita-Kum</title>
  <link href="https://fonts.googleapis.com/css2?family=Merriweather+Sans:wght@300;400;500;600;700&family=Merriweather:wght@400;700;900&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <style>
    h1, h2, h3, h4, .nav-brand { font-family: 'Merriweather', serif; }
    body { font-family: 'Merriweather Sans', sans-serif; background: #fffaf5; color: #111; }
    .panel { border: 1px solid rgba(0,0,0,0.06); border-radius: 18px; background: #fff; padding: 24px; max-width: 1200px; margin: 24px auto; }
    .btn-primary { background: #ff6f00; border-color: #ff6f00; }
    .btn-primary:hover { background: #e65f00; border-color: #e65f00; }
    .section { border: 1px solid rgba(0,0,0,0.06); border-radius: 14px; padding: 18px; margin-bottom: 18px; }
    .confirm-backdrop {
      position: fixed;
      inset: 0;
      display: none;
      align-items: center;
      justify-content: center;
      background: rgba(17, 17, 17, 0.48);
      padding: 20px;
      z-index: 1000;
    }
    .confirm-backdrop.is-open { display: flex; }
    .confirm-dialog {
      width: min(440px, 100%);
      background: #fff;
      border-radius: 12px;
      box-shadow: 0 18px 50px rgba(0,0,0,0.24);
      padding: 24px;
    }
    .confirm-dialog h5 { font-weight: 800; margin-bottom: 10px; }
    .confirm-dialog p { color: #555; margin-bottom: 22px; }
    .confirm-actions { display: flex; justify-content: flex-end; gap: 10px; }
  </style>
</head>
<body>
  <div class="panel">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <div class="d-flex align-items-center gap-3">
        <img src="/img/talita-kum-logo.png" alt="Talita Kum" style="height: 50px; object-fit: contain;">
        <div>
          <h2 class="fw-bold mb-1">Panel de administraci&oacute;n</h2>
          <p class="text-muted mb-0">Gesti&oacute;n de cuentas profesionales e intervenciones</p>
        </div>
      </div>
      <a href="/intervenciones/dashboard" class="btn btn-outline-dark">Volver al dashboard</a>
    </div>

    <div class="section">
      <h4 class="fw-bold mb-3">Cuentas profesionales</h4>
      <% if (profesionales.length === 0) { %>
        <p class="text-muted">No hay solicitudes de profesionales.</p>
      <% } else { %>
        <div class="table-responsive">
          <table class="table table-striped">
            <thead>
              <tr>
                <th>Nombre</th>
                <th>Correo</th>
                <th>Especialidad</th>
                <th>Estado</th>
                <th>Acciones</th>
              </tr>
            </thead>
            <tbody>
              <% profesionales.forEach((item) => { %>
                <tr>
                  <td><%= item.nombre %></td>
                  <td><%= item.correo %></td>
                  <td><%= item.especialidad %></td>
                  <td><%= Number(item.aprobado) === 1 ? 'Aprobada' : 'Pendiente' %></td>
                  <td>
                    <% if (item.aprobado !== 1) { %>
                      <form action="/profesionales/admin/aprobar/<%= item.id %>" method="POST" class="d-inline">
                        <button class="btn btn-sm btn-primary">Aprobar</button>
                      </form>
                    <% } %>
                    <form action="/profesionales/admin/eliminar/<%= item.id %>" method="POST" class="d-inline" onsubmit="return confirm('Desea eliminar esta cuenta profesional?')">
                      <button class="btn btn-sm btn-outline-dark">Eliminar</button>
                    </form>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>
    </div>

    <div class="section">
      <h4 class="fw-bold mb-3">Intervenciones registradas</h4>
      <% if (intervenciones.length === 0) { %>
        <p class="text-muted">No hay intervenciones registradas.</p>
      <% } else { %>
        <div class="table-responsive">
          <table class="table table-striped">
            <thead>
              <tr>
                <th>ID</th>
                <th>Paciente</th>
                <th>Terapeuta</th>
                <th>Fecha</th>
                <th>Descripci&oacute;n</th>
                <th>Acci&oacute;n</th>
              </tr>
            </thead>
            <tbody>
              <% intervenciones.forEach((item) => { %>
                <tr>
                  <td><%= item.id %></td>
                  <td><%= item.paciente %></td>
                  <td><%= item.terapeuta %></td>
                  <td><%= item.fecha %></td>
                  <td><%= item.descripcion %></td>
                  <td>
                    <button
                      class="btn btn-sm btn-outline-dark js-open-delete"
                      type="button"
                      data-delete-url="/intervenciones/eliminar/<%= item.id %>">
                      Borrar intervenci&oacute;n
                    </button>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>
    </div>
  </div>

  <div class="confirm-backdrop" id="deleteModal" aria-hidden="true">
    <div class="confirm-dialog" role="dialog" aria-modal="true" aria-labelledby="deleteTitle">
      <h5 id="deleteTitle">Eliminar intervenci&oacute;n</h5>
      <p>Esta seguro que desea eliminar permanentemente esta intervencion?</p>
      <form id="deleteForm" method="POST">
        <div class="confirm-actions">
          <button type="button" class="btn btn-outline-dark" id="cancelDelete">Cancelar</button>
          <button type="submit" class="btn btn-danger">Eliminar</button>
        </div>
      </form>
    </div>
  </div>

  <script>
    const deleteModal = document.getElementById("deleteModal");
    const deleteForm = document.getElementById("deleteForm");
    const cancelDelete = document.getElementById("cancelDelete");

    document.querySelectorAll(".js-open-delete").forEach((button) => {
      button.addEventListener("click", () => {
        deleteForm.action = button.dataset.deleteUrl;
        deleteModal.classList.add("is-open");
        deleteModal.setAttribute("aria-hidden", "false");
      });
    });

    function closeDeleteModal() {
      deleteModal.classList.remove("is-open");
      deleteModal.setAttribute("aria-hidden", "true");
      deleteForm.removeAttribute("action");
    }

    cancelDelete.addEventListener("click", closeDeleteModal);
    deleteModal.addEventListener("click", (event) => {
      if (event.target === deleteModal) closeDeleteModal();
    });
    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape" && deleteModal.classList.contains("is-open")) {
        closeDeleteModal();
      }
    });
  </script>
</body>
</html>

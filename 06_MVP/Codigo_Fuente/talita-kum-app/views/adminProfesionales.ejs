<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Administrar profesionales - Talita-Kum</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <style>
    body { font-family: Inter, sans-serif; background: #fffaf5; color: #111; }
    .panel { border: 1px solid rgba(0,0,0,0.06); border-radius: 16px; background: #fff; padding: 20px; margin: 24px auto; max-width: 1100px; }
    .btn-primary { background: #ff6f00; border-color: #ff6f00; }
  </style>
</head>
<body>
  <div class="panel">
    <div class="d-flex justify-content-between align-items-center mb-3">
      <div>
        <h3 class="fw-bold mb-1">Administración de profesionales</h3>
        <p class="text-muted mb-0">Aprueba o elimina cuentas de acceso profesional</p>
      </div>
      <a href="/intervenciones/dashboard" class="btn btn-outline-dark">Volver al dashboard</a>
    </div>

    <div class="table-responsive">
      <table class="table table-striped">
        <thead>
          <tr>
            <th>Nombre</th>
            <th>Correo</th>
            <th>Especialidad</th>
            <th>Estado</th>
            <th>Acciones</th>
          </tr>
        </thead>
        <tbody>
          <% terapeutas.forEach((item) => { %>
            <tr>
              <td><%= item.nombre %></td>
              <td><%= item.correo %></td>
              <td><%= item.especialidad %></td>
              <td><%= item.aprobado === 1 ? 'Aprobada' : 'Pendiente' %></td>
              <td>
                <% if (item.aprobado !== 1) { %>
                  <form action="/profesionales/admin/aprobar/<%= item.id %>" method="POST" class="d-inline">
                    <button class="btn btn-sm btn-primary">Aprobar</button>
                  </form>
                <% } %>
                <form action="/profesionales/admin/eliminar/<%= item.id %>" method="POST" class="d-inline" onsubmit="return confirm('¿Desea eliminar esta cuenta?')">
                  <button class="btn btn-sm btn-outline-dark">Eliminar</button>
                </form>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</body>
</html>

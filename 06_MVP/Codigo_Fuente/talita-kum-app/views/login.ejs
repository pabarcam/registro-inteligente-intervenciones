<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Bienvenido - Talita-Kum</title>
  <link href="https://fonts.googleapis.com/css2?family=Merriweather+Sans:wght@300;400;500;600;700&family=Merriweather:wght@400;700;900&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <style>
    :root {
      --naranja: #ff6f00;
      --blanco: #ffffff;
      --negro: #111111;
      --gris: #f7f7f7;
    }

    h1, h2, h3, h4, .nav-brand { font-family: 'Merriweather', serif; }

    body {
      font-family: 'Merriweather Sans', sans-serif;
      background: linear-gradient(135deg, #fff4e6 0%, #ffffff 100%);
      color: var(--negro);
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0;
    }

    .login-shell {
      width: 100%;
      max-width: 420px;
      background: var(--blanco);
      border: 1px solid rgba(0,0,0,0.06);
      border-radius: 18px;
      overflow: hidden;
      box-shadow: 0 18px 40px rgba(0, 0, 0, 0.08);
    }

    .login-header {
      background: var(--naranja);
      color: var(--blanco);
      padding: 24px 28px;
      border-bottom: 1px solid rgba(0,0,0,0.06); box-shadow: 0 4px 16px rgba(0,0,0,0.03);
    }

    .login-title {
      font-size: 1.45rem;
      font-weight: 700;
      margin: 0;
    }

    .login-subtitle {
      margin: 6px 0 0;
      opacity: 0.95;
      font-size: 0.95rem;
    }

    .login-body {
      padding: 28px;
    }

    .form-control {
      border: 1.5px solid var(--negro);
      border-radius: 10px;
      padding: 10px 12px;
    }

    .form-control:focus {
      border-color: var(--naranja);
      box-shadow: none;
    }

    .btn-primary {
      background: var(--naranja);
      border-color: var(--naranja);
      border-radius: 999px;
      font-weight: 700;
      color: var(--blanco);
    }

    .btn-primary:hover {
      background: #e65f00;
      border-color: #e65f00;
      color: var(--blanco);
    }

    .alert-danger {
      border: 1.5px solid var(--negro);
      background: #fff3f3;
      color: var(--negro);
    }
  </style>
</head>
<body>
  <div class="login-shell">
    <div class="login-header">
      <h3 class="login-title">Bienvenido - Talita-Kum</h3>
      <p class="login-subtitle">Acceso seguro al registro de intervenciones</p>
    </div>
    <div class="login-body">
      <% if (error) { %>
        <div class="alert alert-danger"><%= error %></div>
      <% } %>

      <form action="/login" method="POST">
        <div class="mb-3">
          <label class="form-label">Correo</label>
          <input type="email" name="correo" class="form-control" required>
        </div>

        <div class="mb-3">
          <label class="form-label">Contraseña</label>
          <input type="password" name="password" class="form-control" required>
        </div>

        <button class="btn btn-primary w-100">Ingresar</button>
      </form>
    </div>
  </div>
</body>
</html>
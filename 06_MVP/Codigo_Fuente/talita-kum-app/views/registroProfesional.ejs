<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Registro profesional - Talita-Kum</title>
  <link href="https://fonts.googleapis.com/css2?family=Merriweather+Sans:wght@300;400;500;600;700&family=Merriweather:wght@400;700;900&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <style>
    h1, h2, h3, h4, .nav-brand { font-family: 'Merriweather', serif; }

    body {
      font-family: 'Merriweather Sans', sans-serif; background: #fff7eb; color: #111; min-height: 100vh; display: flex; align-items: center; justify-content: center; }
    .card { border: 1px solid rgba(0,0,0,0.06); border-radius: 18px; box-shadow: 0 16px 40px rgba(0,0,0,0.06); }
    .btn-primary { background: #ff6f00; border-color: #ff6f00; }
    .btn-primary:hover { background: #e65f00; border-color: #e65f00; }
  </style>
</head>
<body>
  <div class="card p-4" style="width: min(92vw, 480px);">
    <div class="text-center mb-4">
        <img src="/img/talita-kum-logo.png" alt="Talita Kum" style="height: 60px; object-fit: contain;">
    </div>
    <h3 class="fw-bold mb-2">Registro profesional</h3>
    <p class="text-muted">Crea tu cuenta con tu correo institucional y espera aprobación.</p>
    <% if (message) { %>
      <div class="alert alert-info"><%= message %></div>
    <% } %>
    <% if (error) { %>
      <div class="alert alert-danger"><%= error %></div>
    <% } %>
    <form action="/profesionales/registro" method="POST">
      <div class="mb-3">
        <label class="form-label">Nombre completo</label>
        <input type="text" name="nombre" class="form-control" placeholder="ej: Paulo Abarca" required>
      </div>
      <div class="mb-3">
        <label class="form-label">Correo institucional</label>
        <input type="email" name="correo" class="form-control" placeholder="ej: paulo@talita.cl" required>
      </div>
      <div class="mb-3">
        <label class="form-label">Contraseña</label>
        <input type="password" name="password" id="password" class="form-control" placeholder="Mín. 8 caracteres, 1 mayúscula, 1 número y 1 símbolo" required minlength="8">
        <div id="passwordHelp" class="form-text" style="font-size:0.8rem;color:#888;">
          Mínimo 8 caracteres, 1 mayúscula, 1 número y 1 símbolo (ej: @ # $ % & !).
        </div>
      </div>
      <div class="mb-3">
        <label class="form-label">Confirmar contraseña</label>
        <input type="password" name="password_confirm" id="password_confirm" class="form-control" placeholder="Repite la contraseña" required minlength="8">
        <div id="confirmError" class="form-text" style="font-size:0.8rem;color:#c62828;display:none;">Las contraseñas no coinciden.</div>
      </div>
      <div class="mb-3">
        <label class="form-label">Especialidad</label>
        <input type="text" name="especialidad" class="form-control" placeholder="ej: Psicología clínica" required>
      </div>
      <button class="btn btn-primary w-100">Solicitar acceso</button>
    </form>
    <div class="mt-3 text-center">
      <a href="/profesionales/login" class="text-decoration-none">Volver al login</a>
    </div>
  </div>

  <script>
    const password = document.getElementById('password');
    const passwordConfirm = document.getElementById('password_confirm');
    const confirmError = document.getElementById('confirmError');
    const form = document.querySelector('form');

    function validatePassword() {
      const val = password.value;
      const hasUpper = /[A-Z]/.test(val);
      const hasNumber = /[0-9]/.test(val);
      const hasSymbol = /[^a-zA-Z0-9]/.test(val);
      const hasMinLen = val.length >= 8;

      password.setCustomValidity('');
      if (val && !(hasUpper && hasNumber && hasSymbol && hasMinLen)) {
        password.setCustomValidity('Debe tener mínimo 8 caracteres, 1 mayúscula, 1 número y 1 símbolo.');
      }
    }

    function validateConfirm() {
      if (passwordConfirm.value && passwordConfirm.value !== password.value) {
        confirmError.style.display = 'block';
        passwordConfirm.setCustomValidity('Las contraseñas no coinciden.');
      } else {
        confirmError.style.display = 'none';
        passwordConfirm.setCustomValidity('');
      }
    }

    password.addEventListener('input', validatePassword);
    passwordConfirm.addEventListener('input', validateConfirm);
  </script>
</body>
</html>

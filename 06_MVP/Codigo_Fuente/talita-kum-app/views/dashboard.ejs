<!DOCTYPE html>
<html lang="es">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dashboard — Talita-Kum</title>
  <link href="https://fonts.googleapis.com/css2?family=Merriweather+Sans:wght@300;400;500;600;700&family=Merriweather:wght@400;700;900&display=swap" rel="stylesheet">
  <style>
    :root {
      --naranja: #ff6f00;
      --naranja-light: #fff3e0;
      --negro: #111111;
      --blanco: #ffffff;
      --gris: #f9f6f2;
      --borde: #e0d8cf;
      --sombra: 0 8px 32px rgba(0, 0, 0, 0.09);
      --radio: 20px;
    }

    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    h1, h2, h3, h4, .nav-brand { font-family: 'Merriweather', serif; }

    body {
      font-family: 'Merriweather Sans', sans-serif;
      background: #fdfdfd;
      color: var(--negro);
      min-height: 100vh;
    }

    /* ── NAV ─────────────────────────────────── */
    nav {
      background: var(--blanco);
      border-bottom: 1px solid rgba(0,0,0,0.06); box-shadow: 0 4px 16px rgba(0,0,0,0.03);
      padding: 14px 40px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 16px;
      flex-wrap: wrap;
    }

    .nav-brand {
      font-weight: 700;
      font-size: 1.15rem;
      letter-spacing: -0.5px;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .nav-brand em {
      color: var(--naranja);
      font-style: normal;
    }

    .nav-actions {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
    }

    .btn {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 9px 20px;
      border-radius: 999px;
      font-weight: 600;
      font-size: 0.875rem;
      text-decoration: none;
      cursor: pointer;
      border: 2px solid transparent;
      transition: background 0.18s, color 0.18s;
    }

    .btn-orange {
      background: var(--naranja);
      color: var(--blanco);
      border-color: var(--naranja);
    }

    .btn-orange:hover {
      background: #e65f00;
      border-color: #e65f00;
      color: var(--blanco);
    }

    .btn-outline {
      background: var(--blanco);
      color: var(--negro);
      border-color: var(--negro);
    }

    .btn-outline:hover {
      background: var(--negro);
      color: var(--blanco);
    }

    /* ── LAYOUT ──────────────────────────────── */
    .page {
      max-width: 1080px;
      margin: 36px auto;
      padding: 0 24px 60px;
    }

    /* ── HEADER ──────────────────────────────── */
    .dash-header {
      margin-bottom: 36px;
    }

    .dash-header h1 {
      font-size: 2rem;
      font-weight: 700;
      letter-spacing: -0.5px;
      margin-bottom: 4px;
    }

    .dash-header p {
      color: #6b6b6b;
      font-size: 0.95rem;
    }

    /* ── SECTION TITLE ───────────────────────── */
    .section-title {
      font-size: 1.05rem;
      font-weight: 700;
      margin-bottom: 16px;
      padding-bottom: 8px;
      border-bottom: 1px solid rgba(0,0,0,0.06); box-shadow: 0 4px 16px rgba(0,0,0,0.03);
      display: flex;
      align-items: center;
      gap: 8px;
    }

    /* ── PACIENTES GRID ──────────────────────── */
    .patients-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
      gap: 16px;
      margin-bottom: 44px;
    }

    .patient-card {
      background: var(--blanco);
      border: 1px solid rgba(0,0,0,0.06);
      border-radius: var(--radio);
      padding: 22px;
      text-decoration: none;
      color: var(--negro);
      display: flex;
      flex-direction: column;
      gap: 12px;
      transition: transform 0.18s, box-shadow 0.18s;
      box-shadow: var(--sombra);
      position: relative;
      overflow: hidden;
    }

    .patient-card::after {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 4px;
      background: var(--naranja);
      transform: scaleX(0);
      transform-origin: left;
      transition: transform 0.25s ease;
    }

    .patient-card:hover {
      transform: translateY(-4px);
      box-shadow: 0 16px 40px rgba(0, 0, 0, 0.14);
    }

    .patient-card:hover::after {
      transform: scaleX(1);
    }

    .patient-avatar {
      width: 44px;
      height: 44px;
      border-radius: 50%;
      background: var(--naranja-light);
      border: 2px solid var(--naranja);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.25rem;
    }

    .patient-name {
      font-weight: 700;
      font-size: 1rem;
      line-height: 1.3;
    }

    .patient-meta {
      font-size: 0.8rem;
      color: #888;
      font-weight: 500;
    }

    .patient-badge {
      display: inline-block;
      background: var(--naranja-light);
      color: var(--naranja);
      border: 1.5px solid var(--naranja);
      border-radius: 999px;
      padding: 3px 11px;
      font-size: 0.78rem;
      font-weight: 700;
      align-self: flex-start;
    }

    .patient-cta {
      margin-top: auto;
      font-size: 0.82rem;
      font-weight: 600;
      color: var(--naranja);
      display: flex;
      align-items: center;
      gap: 4px;
    }

    /* ── EMPTY STATE ─────────────────────────── */
    .empty {
      background: var(--blanco);
      border: 2px dashed var(--borde);
      border-radius: var(--radio);
      padding: 48px 32px;
      text-align: center;
      color: #9b8b7b;
    }

    .empty p {
      margin-top: 10px;
      font-size: 0.95rem;
    }

    /* ── ADMIN PANEL ─────────────────────────── */
    .admin-panel {
      background: var(--blanco);
      border: 1px solid rgba(0,0,0,0.06);
      border-radius: var(--radio);
      padding: 28px;
      box-shadow: var(--sombra);
    }

    .admin-panel h2 {
      font-size: 1.1rem;
      font-weight: 700;
      margin-bottom: 10px;
    }

    .admin-panel p {
      color: #6b6b6b;
      font-size: 0.9rem;
      margin-bottom: 20px;
    }
  </style>
</head>

<body>

  <% const isAdmin=usuario && usuario.rol==='admin' ; const isProfesional=usuario && !isAdmin; const
    nombreUsuario=usuario && usuario.nombre ? usuario.nombre : (usuario && usuario.correo ? usuario.correo : 'Usuario'
    ); %>

    <!-- NAV -->
    <nav>
      <div class="nav-brand"><img src="/img/talita-kum-logo.png" alt="Talita Kum" style="height: 48px; object-fit: contain;"></div>
      <div class="nav-actions">
        <% if (isProfesional) { %>
          <a href="/intervenciones/nueva" class="btn btn-orange">+ Nueva Intervención</a>
          <a href="/profesionales/historial" class="btn btn-outline">📋 Historial</a>
          <% } %>
            <% if (isAdmin) { %>
              <a href="/profesionales/admin" class="btn btn-outline">⚙️ Administración</a>
              <% } %>
                <a href="/logout" class="btn btn-outline">← Salir</a>
      </div>
    </nav>

    <!-- ── FLASH SUCCESS ── -->
    <% if (typeof flashSuccess !=='undefined' && flashSuccess) { %>
      <div id="flashBanner" style="
    position:fixed; top:20px; left:50%; transform:translateX(-50%);
    background:#111; color:#fff; padding:14px 28px; border-radius:999px;
    font-weight:700; font-size:0.95rem; z-index:9999;
    display:flex; align-items:center; gap:10px;
    box-shadow:0 8px 32px rgba(0,0,0,0.22);
    animation: slideDown 0.4s ease;
  ">
        <span style="color:#ff6f00;font-size:1.1rem;">✅</span>
        <%= flashSuccess %>
          <span style="color:#888;font-size:0.75rem;font-weight:400;margin-left:8px;">📧 Resumen enviado por
            email</span>
      </div>
      <style>
        @keyframes slideDown {
          from {
            opacity: 0;
            transform: translateX(-50%) translateY(-16px);
          }

          to {
            opacity: 1;
            transform: translateX(-50%) translateY(0);
          }
        }
      </style>
      <script>
        setTimeout(() => {
          const b = document.getElementById('flashBanner');
          if (b) { b.style.transition = 'opacity 0.4s'; b.style.opacity = '0'; setTimeout(() => b.remove(), 400); }
        }, 5000);
      </script>
      <% } %>

        <div class="page">

          <div class="dash-header">
            <h1>
              <%= isAdmin ? '⚙️ Gestión admin' : '🌿 Mi Dashboard' %>
            </h1>
            <p>Bienvenida, <strong>
                <%= nombreUsuario %>
              </strong></p>
          </div>

          <% if (isAdmin) { %>
            <!-- ── ADMIN ── -->
            <div class="admin-panel">
              <h2>Panel de administración</h2>
              <p>Desde aquí puedes administrar las cuentas profesionales y los registros del sistema.</p>
              <a href="/profesionales/admin" class="btn btn-orange">Ir a gestión admin</a>
            </div>

            <% } else { %>
              <!-- ── TERAPEUTA: listado de pacientes ── -->
              <div class="section-title">👤 Mis pacientes</div>

              <% if (!patientGroups || patientGroups.length===0) { %>
                <div class="empty">
                  <div style="font-size:2.5rem">🗂️</div>
                  <p>Aún no tienes pacientes registrados.<br>¡Registra tu primera intervención!</p>
                  <a href="/intervenciones/nueva" class="btn btn-orange" style="margin-top:20px; display:inline-flex">+
                    Nueva Intervención</a>
                </div>
                <% } else { %>
                  <div class="patients-grid">
                    <% patientGroups.forEach((group)=> { %>
                      <% const slug=group.paciente.replace(/[^a-z0-9]+/gi, '-' ).toLowerCase(); const
                        initials=group.paciente.trim().split(' ').map(w => w[0]).join('').slice(0,2).toUpperCase();
            %>
            <a href="/intervenciones/paciente/<%= encodeURIComponent(group.paciente) %>" class="patient-card" id="paciente-<%= slug %>">
              <div class="patient-avatar"><%= initials %></div>
              <div>
                <div class="patient-name"><%= group.paciente %></div>
                <div class="patient-meta">Última sesión: <%= group.ultimaFecha || ' Sin fecha' %>
                  </div>
        </div>
        <span class="patient-badge">
          <%= group.count %>
            <%= group.count===1 ? 'registro' : 'registros' %>
        </span>
        <div class="patient-cta">Ver dashboard completo →</div>
        </a>
        <% }) %>
          </div>
          <% } %>

            <% } %>
              </div>

</body>

</html>
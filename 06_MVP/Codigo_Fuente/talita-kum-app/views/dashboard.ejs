<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <title>Dashboard - Talita Kum</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
  <div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <div>
        <h1>Dashboard</h1>
        <p class="text-muted">Bienvenido, <%= usuario && usuario.nombre ? usuario.nombre : usuario.correo %></p>
      </div>
      <div>
        <a href="/intervenciones/nueva" class="btn btn-success me-2">Nueva Intervención</a>
        <a href="/logout" class="btn btn-outline-secondary">Cerrar sesión</a>
      </div>
    </div>

    <div class="card mb-4">
      <div class="card-body">
        <h5 class="card-title">Síntesis asistida por IA</h5>
        <% if (summaries.length === 0) { %>
          <p class="text-muted mb-0">Aún no hay suficiente información para generar síntesis.</p>
        <% } else { %>
          <% summaries.forEach((item) => { %>
            <div class="border rounded p-3 mb-3">
              <div class="d-flex justify-content-between align-items-start mb-2">
                <strong><%= item.paciente %></strong>
                <span class="badge bg-info text-dark"><%= item.count %> registros</span>
              </div>
              <p class="mb-0"><%= item.resumen %></p>
            </div>
          <% }) %>
        <% } %>
      </div>
    </div>

    <div class="card">
      <div class="card-body">
        <h5 class="card-title">Intervenciones registradas</h5>
        <% if (intervenciones.length === 0) { %>
          <p class="text-muted mb-0">No hay intervenciones registradas aún.</p>
        <% } else { %>
          <div class="table-responsive">
            <table class="table table-striped">
              <thead>
                <tr>
                  <th>ID</th>
                  <th>Paciente</th>
                  <th>Terapeuta</th>
                  <th>Fecha</th>
                  <th>Descripción</th>
                </tr>
              </thead>
              <tbody>
                <% intervenciones.forEach((item) => { %>
                  <tr>
                    <td><%= item.id %></td>
                    <td><%= item.paciente %></td>
                    <td><%= item.terapeuta %></td>
                    <td><%= item.fecha %></td>
                    <td><%= item.descripcion %></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } %>
      </div>
    </div>
  </div>
</body>
</html>
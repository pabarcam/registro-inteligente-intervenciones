<!DOCTYPE html>
<html>

<head>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
rel="stylesheet">

</head>

<body>

<div class="container mt-4">

<h2>Nueva Intervención</h2>

<form
action="/intervenciones/guardar"
method="POST">

<label>Paciente</label>

<input
name="paciente"
class="form-control">

<label class="mt-3">
Descripción
</label>

<textarea
name="descripcion"
class="form-control"></textarea>

<label class="mt-3">
Objetivo
</label>

<textarea
name="objetivo"
class="form-control"></textarea>

<label class="mt-3">
Acuerdos
</label>

<textarea
name="acuerdos"
class="form-control"></textarea>

<label class="mt-3">
Observaciones
</label>

<textarea
name="observaciones"
class="form-control"></textarea>

<button
class="btn btn-primary mt-3">

Guardar

</button>

</form>

</div>

</body>
</html>
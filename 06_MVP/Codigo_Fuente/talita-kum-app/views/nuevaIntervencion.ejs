<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <title>Nueva intervención - Talita Kum</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
  <div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <h2>Nueva Intervención</h2>
      <a href="/intervenciones/dashboard" class="btn btn-outline-secondary">Volver al dashboard</a>
    </div>

    <form action="/intervenciones/guardar" method="POST" class="card p-4">
      <div class="row g-3">
        <div class="col-md-6">
          <label class="form-label">Paciente</label>
          <input name="paciente" class="form-control" required>
        </div>
        <div class="col-md-6">
          <label class="form-label">Terapeuta</label>
          <input name="terapeuta" class="form-control" value="<%= usuario && usuario.nombre ? usuario.nombre : '' %>">
        </div>
        <div class="col-md-6">
          <label class="form-label">Fecha</label>
          <input type="date" name="fecha" class="form-control">
        </div>
        <div class="col-12">
          <label class="form-label d-flex justify-content-between align-items-center">
            <span>Descripción</span>
            <button type="button" class="btn btn-outline-secondary btn-sm" data-voice-target="descripcion">🎤 Dictar</button>
          </label>
          <textarea name="descripcion" id="descripcion" class="form-control" rows="3"></textarea>
        </div>
        <div class="col-12">
          <label class="form-label d-flex justify-content-between align-items-center">
            <span>Objetivo</span>
            <button type="button" class="btn btn-outline-secondary btn-sm" data-voice-target="objetivo">🎤 Dictar</button>
          </label>
          <textarea name="objetivo" id="objetivo" class="form-control" rows="3"></textarea>
        </div>
        <div class="col-12">
          <label class="form-label d-flex justify-content-between align-items-center">
            <span>Acuerdos</span>
            <button type="button" class="btn btn-outline-secondary btn-sm" data-voice-target="acuerdos">🎤 Dictar</button>
          </label>
          <textarea name="acuerdos" id="acuerdos" class="form-control" rows="3"></textarea>
        </div>
        <div class="col-12">
          <label class="form-label d-flex justify-content-between align-items-center">
            <span>Observaciones</span>
            <button type="button" class="btn btn-outline-secondary btn-sm" data-voice-target="observaciones">🎤 Dictar</button>
          </label>
          <textarea name="observaciones" id="observaciones" class="form-control" rows="3"></textarea>
        </div>
      </div>

      <button class="btn btn-primary mt-4">Guardar</button>
    </form>
  </div>
  <script src="/js/voice-api.js"></script>
</body>
</html>
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Historial profesional - Talita-Kum</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <style>
    body { font-family: Inter, sans-serif; background: #fffaf5; color: #111; }
    .panel { border: 1px solid rgba(0,0,0,0.06); border-radius: 16px; background: #fff; padding: 20px; margin: 24px auto; max-width: 1100px; }
    .btn-primary { background: #ff6f00; border-color: #ff6f00; }
    .btn-primary:hover { background: #e65f00; border-color: #e65f00; }
    .desc-cell { max-width: 300px; white-space: pre-wrap; font-size: 0.9rem; }
    .action-btns { display: flex; gap: 8px; }
  </style>
</head>
<body>
  <div class="panel">
    <div class="d-flex justify-content-between align-items-center mb-3">
      <div class="d-flex align-items-center gap-3">
        <img src="/img/talita-kum-logo.png" alt="Talita Kum" style="height: 50px; object-fit: contain;">
        <div>
          <h3 class="fw-bold mb-1">Historial profesional</h3>
          <p class="text-muted mb-0">Mostrando solo tus intervenciones registradas</p>
        </div>
      </div>
      <a href="/intervenciones/dashboard" class="btn btn-outline-dark">Volver al dashboard</a>
    </div>

    <% if (intervenciones.length === 0) { %>
      <p class="text-muted">Todavía no hay intervenciones para este profesional.</p>
    <% } else { %>
      <div class="table-responsive">
        <table class="table table-striped align-middle">
          <thead>
            <tr>
              <th>Paciente</th>
              <th>Sesión</th>
              <th>Fecha</th>
              <th>Descripción</th>
              <th>Acciones</th>
            </tr>
          </thead>
          <tbody>
            <% intervenciones.forEach((item) => { %>
              <tr>
                <td class="fw-bold"><%= item.paciente %></td>
                <td>Sesión #<%= item.sesionNumber %></td>
                <td><%= item.fecha %></td>
                <td class="desc-cell"><%= item.descripcion || 'Sin descripción' %></td>
                <td>
                  <div class="action-btns">
                    <!-- Botón Editar -->
                    <button type="button" class="btn btn-sm btn-outline-primary" data-bs-toggle="modal" data-bs-target="#editModal-<%= item.id %>">
                      Editar
                    </button>
                    <!-- Formulario Eliminar -->
                    <form action="/intervenciones/eliminar/<%= item.id %>" method="POST" onsubmit="return confirm('¿Seguro que deseas eliminar esta intervención?');">
                      <button type="submit" class="btn btn-sm btn-outline-danger">Eliminar</button>
                    </form>
                  </div>

                  <!-- Modal Editar -->
                  <div class="modal fade" id="editModal-<%= item.id %>" tabindex="-1" aria-hidden="true">
                    <div class="modal-dialog modal-lg">
                      <div class="modal-content">
                        <form action="/intervenciones/editar/<%= item.id %>" method="POST">
                          <div class="modal-header">
                            <h5 class="modal-title">Editar Descripción</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                          </div>
                          <div class="modal-body">
                            <p class="mb-2"><strong>Paciente:</strong> <%= item.paciente %> — <strong>Fecha:</strong> <%= item.fecha %></p>
                            <textarea name="descripcion" class="form-control" rows="10" required><%= item.descripcion %></textarea>
                          </div>
                          <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                            <button type="submit" class="btn btn-primary">Guardar cambios</button>
                          </div>
                        </form>
                      </div>
                    </div>
                  </div>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dashboard de <%= paciente %> — Talita-Kum</title>
  <link href="https://fonts.googleapis.com/css2?family=Merriweather+Sans:wght@300;400;500;600;700&family=Merriweather:wght@400;700;900&display=swap" rel="stylesheet">
  <style>
    :root {
      --naranja: #ff6f00;
      --naranja-light: #fff3e0;
      --negro: #111111;
      --blanco: #ffffff;
      --gris: #f9f6f2;
      --borde: #e0d8cf;
      --sombra: 0 8px 32px rgba(0,0,0,0.09);
      --radio: 20px;
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }

    h1, h2, h3, h4, .nav-brand { font-family: 'Merriweather', serif; }

    body {
      font-family: 'Merriweather Sans', sans-serif;
      background: #fdfdfd;
      color: var(--negro);
      min-height: 100vh;
    }

    /* ── NAV ─────────────────────────────────── */
    nav {
      background: var(--blanco);
      border-bottom: 1px solid rgba(0,0,0,0.06); box-shadow: 0 4px 16px rgba(0,0,0,0.03);
      padding: 14px 40px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 16px;
      flex-wrap: wrap;
    }

    .nav-brand {
      font-weight: 700;
      font-size: 1.15rem;
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .nav-brand em { color: var(--naranja); font-style: normal; }

    .btn {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 9px 20px;
      border-radius: 999px;
      font-weight: 600;
      font-size: 0.875rem;
      text-decoration: none;
      cursor: pointer;
      border: 2px solid transparent;
      transition: background 0.18s, color 0.18s;
    }

    .btn-outline { background: transparent; color: #555; border: 1px solid rgba(0,0,0,0.15); }
    .btn-outline:hover { background: rgba(0,0,0,0.03); color: var(--negro); border-color: rgba(0,0,0,0.3); }

    .btn-orange { background: var(--naranja); color: var(--blanco); border-color: var(--naranja); }
    .btn-orange:hover { background: #e65f00; border-color: #e65f00; color: var(--blanco); }

    /* ── LAYOUT ──────────────────────────────── */
    .page { max-width: 900px; margin: 36px auto; padding: 0 24px 80px; }

    /* ── BREADCRUMB ──────────────────────────── */
    .breadcrumb {
      font-size: 0.82rem;
      color: #9b8b7b;
      margin-bottom: 20px;
      display: flex;
      align-items: center;
      gap: 6px;
    }
    .breadcrumb a { color: var(--naranja); text-decoration: none; font-weight: 600; }
    .breadcrumb a:hover { text-decoration: underline; }

    /* ── PATIENT HEADER ──────────────────────── */
    .patient-header {
      display: flex;
      align-items: center;
      gap: 20px;
      margin-bottom: 36px;
    }

    .patient-avatar-lg {
      width: 70px;
      height: 70px;
      border-radius: 50%;
      background: var(--naranja-light);
      border: 3px solid var(--naranja);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.75rem;
      font-weight: 700;
      color: var(--naranja);
      flex-shrink: 0;
    }

    .patient-header h1 {
      font-size: 1.75rem;
      font-weight: 700;
      letter-spacing: -0.5px;
      margin-bottom: 4px;
    }

    .patient-header .meta {
      font-size: 0.9rem;
      color: #7b6f64;
      display: flex;
      gap: 16px;
      flex-wrap: wrap;
    }

    .meta-item { display: flex; align-items: center; gap: 5px; }

    /* ── RESUMEN IA ──────────────────────────── */
    .ia-header {
      background: linear-gradient(135deg, #111111 0%, #2b1800 100%);
      border-radius: var(--radio);
      padding: 22px 28px;
      margin-bottom: 20px;
      color: var(--blanco);
      display: flex;
      align-items: center;
      gap: 12px;
      box-shadow: 0 12px 40px rgba(0,0,0,0.18);
    }

    .ia-label {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      background: var(--naranja);
      color: var(--blanco);
      border-radius: 999px;
      padding: 4px 14px;
      font-size: 0.78rem;
      font-weight: 700;
      letter-spacing: 0.5px;
      text-transform: uppercase;
      flex-shrink: 0;
    }

    .ia-header h2 { font-size: 1rem; font-weight: 700; opacity: 0.85; margin: 0; }

    .section-grid { display: flex; flex-direction: column; gap: 14px; margin-bottom: 28px; }

    .sec-card {
      background: var(--blanco);
      border: 1px solid rgba(0,0,0,0.06);
      border-radius: 14px;
      overflow: hidden;
      box-shadow: 0 4px 16px rgba(0,0,0,0.04);
    }

    .sec-title {
      background: var(--negro);
      color: var(--blanco);
      padding: 10px 20px;
      font-weight: 700;
      font-size: 0.85rem;
      letter-spacing: 0.3px;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .sec-content {
      padding: 16px 20px;
      font-size: 0.92rem;
      line-height: 1.7;
      color: #333;
      white-space: pre-wrap;
    }

    /* ── SECCIÓN REGISTROS ───────────────────── */
    .section-title {
      font-size: 1rem;
      font-weight: 700;
      margin-bottom: 16px;
      padding-bottom: 8px;
      border-bottom: 1px solid rgba(0,0,0,0.06); box-shadow: 0 4px 16px rgba(0,0,0,0.03);
      display: flex;
      align-items: center;
      gap: 8px;
    }

    /* ── REGISTRO CARD ───────────────────────── */
    .registro-card {
      background: var(--blanco);
      border: 1px solid rgba(0,0,0,0.06);
      border-radius: 16px;
      margin-bottom: 16px;
      overflow: hidden;
      box-shadow: var(--sombra);
      transition: box-shadow 0.18s;
    }

    .registro-card:hover { box-shadow: 0 14px 40px rgba(0,0,0,0.13); }

    .registro-header {
      background: var(--negro);
      color: var(--blanco);
      padding: 12px 20px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 12px;
    }

    .registro-header .fecha {
      font-weight: 700;
      font-size: 0.9rem;
      display: flex;
      align-items: center;
      gap: 6px;
    }

    .registro-header .num {
      font-size: 0.78rem;
      opacity: 0.6;
    }

    .registro-body {
      padding: 20px;
    }

    .registro-body p {
      font-size: 0.92rem;
      line-height: 1.7;
      color: #333;
      white-space: pre-wrap;
    }

    .registro-audio {
      margin-top: 14px;
      padding-top: 14px;
      border-top: 1.5px solid var(--borde);
    }

    .registro-audio label {
      font-size: 0.8rem;
      font-weight: 600;
      color: #888;
      margin-bottom: 6px;
      display: block;
    }

    .registro-audio audio { width: 100%; border-radius: 8px; }

    /* ── EMPTY ───────────────────────────────── */
    .empty {
      background: var(--blanco);
      border: 2px dashed var(--borde);
      border-radius: var(--radio);
      padding: 48px 32px;
      text-align: center;
      color: #9b8b7b;
    }
  </style>
</head>
<body>

  <%
    const initials = paciente.trim().split(' ').map(w => w[0]).join('').slice(0,2).toUpperCase();
    const totalReg = registros ? registros.length : 0;
    const ultimaFecha = registros && registros.length > 0 ? registros[0].fecha : null;
  %>

  <!-- NAV -->
  <nav>
    <div class="nav-brand"><img src="/img/talita-kum-logo.png" alt="Talita Kum" style="height: 48px; object-fit: contain;"></div>
    <div class="nav-actions"><a href="/intervenciones/dashboard" class="btn btn-outline">← Volver al dashboard</a></div>
  </nav>

  <div class="page">

    <!-- BREADCRUMB -->
    <div class="breadcrumb">
      <a href="/intervenciones/dashboard">🌿 Mi Dashboard</a>
      <span>›</span>
      <span><%= paciente %></span>
    </div>

    <!-- PATIENT HEADER -->
    <div class="patient-header">
      <div class="patient-avatar-lg"><%= initials %></div>
      <div>
        <h1><%= paciente %></h1>
        <div class="meta">
          <span class="meta-item">📋 <%= totalReg %> <%= totalReg === 1 ? 'intervención' : 'intervenciones' %></span>
          <% if (ultimaFecha) { %><span class="meta-item">🗓️ Última: <%= ultimaFecha %></span><% } %>
          <span class="meta-item">👩‍⚕️ Terapeuta: <%= terapeuta %></span>
        </div>
      </div>
    </div>

    <!-- RESUMEN IA -->
    <div class="ia-header">
      <div class="ia-label">✦ Análisis IA</div>
      <h2>Resumen clínico de <%= paciente %></h2>
    </div>

    <% if (typeof sections !== 'undefined' && sections && sections.length > 0) { %>
      <div class="section-grid">
        <% sections.forEach(function(sec, idx) { %>
          <div class="sec-card">
            <div class="sec-title">
              <span style="background:var(--naranja);color:#fff;border-radius:50%;width:22px;height:22px;display:inline-flex;align-items:center;justify-content:center;font-size:0.75rem;font-weight:700;"><%= idx + 1 %></span>
              <%= sec.title %>
            </div>
            <div class="sec-content"><%= sec.content %></div>
          </div>
        <% }) %>
      </div>
    <% } else { %>
      <div style="background:var(--blanco);border:2px dashed var(--borde);border-radius:var(--radio);padding:40px 24px;text-align:center;color:#9b8b7b;margin-bottom:28px;">
        <div style="font-size:2.5rem;margin-bottom:10px;">📋</div>
        <p style="font-size:0.95rem;">Cargando análisis clínico… Agrega más registros para obtener un resumen detallado.</p>
      </div>
    <% } %>

    <!-- REGISTROS COMPLETOS -->
    <div class="section-title">📂 Historial completo de intervenciones</div>

    <% if (!registros || registros.length === 0) { %>
      <div class="empty">
        <div style="font-size:2.5rem">🗂️</div>
        <p>No hay intervenciones registradas aún para este paciente.</p>
      </div>
    <% } else { %>
      <% registros.forEach((item, i) => { %>
        <div class="registro-card">
          <div class="registro-header">
            <span class="fecha">🗓️ <%= item.fecha || 'Sin fecha' %></span>
            <span class="num">Sesión #<%= totalReg - i %></span>
          </div>
          <div class="registro-body">
            <p><%= item.descripcion || 'Sin descripción registrada.' %></p>
            <% if (item.audio_path) { %>
              <div class="registro-audio">
                <label>🎙️ Audio de sesión</label>
                <audio controls>
                  <source src="<%= item.audio_path %>" type="audio/webm">
                  Tu navegador no soporta reproducción de audio.
                </audio>
              </div>
            <% } %>
          </div>
        </div>
      <% }) %>
    <% } %>

  </div>
<script src="/js/inactivity.js"></script>
</body>

</html>

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Acceso administrador - Talita-Kum</title>
  <link href="https://fonts.googleapis.com/css2?family=Merriweather+Sans:wght@300;400;500;600;700&family=Merriweather:wght@400;700;900&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <style>
    h1, h2, h3, h4, .nav-brand { font-family: 'Merriweather', serif; }

    body {
      font-family: 'Merriweather Sans', sans-serif; background: #fff7eb; color: #111; min-height: 100vh; display: flex; align-items: center; justify-content: center; }
    .card { border: 1px solid rgba(0,0,0,0.06); border-radius: 18px; box-shadow: 0 16px 35px rgba(0, 0, 0, .08); }
    .btn-primary { background: #ff6f00; border-color: #ff6f00; }
    .btn-primary:hover { background: #e65f00; border-color: #e65f00; }
  </style>
</head>
<body>
  <div class="card p-4" style="width: min(92vw, 420px);">
    <div class="text-center mb-4">
      <img src="/img/talita-kum-logo.png" alt="Talita Kum" style="height: 60px; object-fit: contain;">
    </div>
    <h3 class="fw-bold mb-2">Acceso administrador</h3>
    <p class="text-muted">Ingresa con tus credenciales de administración</p>
    <% if (error) { %>
      <div class="alert alert-danger"><%= error %></div>
    <% } %>
    <form action="/login-admin" method="POST">
      <div class="mb-3">
        <label class="form-label">Correo</label>
        <input type="email" name="correo" class="form-control" placeholder="ej: admin@talita.com" required>
      </div>
      <div class="mb-3">
        <label class="form-label">Contraseña</label>
        <input type="password" name="password" class="form-control" placeholder="Ingresa tu contraseña" required>
      </div>
      <button class="btn btn-primary w-100">Ingresar</button>
    </form>
    <div class="mt-3 text-center">
      <a href="/profesionales/login" class="text-decoration-none">Volver a login profesional</a>
    </div>
  </div>
</body>
</html>
